G':'<img\x20src=\x22icons/video.png\x22\x20style=\x22width:\x20100%;\x20height:\x20100%;\x20object-fit:\x20contain;\x22>','content':{'type':'video','payload':''}},'window-notepad':{'title':'Notepad','width':0x41a,'height':0x384,'top':'8%','left':'25%','maximizable':!![],'showInTaskbar':!![],'iconType':'notepad','iconSVG':'<img\x20src=\x22icons/notepad.png\x22\x20style=\x22width:\x20100%;\x20height:\x20100%;\x20object-fit:\x20contain;\x22>','content':{'type':'notepad','payloadUrl':'file_sys/about-me.txt'}},'window-text-viewer':{'title':'Text\x20Viewer','width':0x41a,'height':0x384,'top':'8%','left':'25%','maximizable':!![],'showInTaskbar':!![],'iconType':'notepad','iconSVG':'<img\x20src=\x22icons/notepad.png\x22\x20style=\x22width:\x20100%;\x20height:\x20100%;\x20object-fit:\x20contain;\x22>','content':{'type':'notepad','payload':''}},'window-paint':{'title':'Paint','width':0x4ee,'height':0x3bb,'top':'10%','left':'15%','maximizable':!![],'showInTaskbar':!![],'iconType':'paint','iconSVG':'<img\x20src=\x22icons/paint/paint.png\x22\x20style=\x22width:\x20100%;\x20height:\x20100%;\x20object-fit:\x20contain;\x22>','content':{'type':'paint','payload':''}},'window-messenger':{'title':'Messenger','width':0x438,'height':0x35c,'top':'10%','left':'15%','theme':'','iconSVG':'<img\x20src=\x27icons/messenger.png\x27\x20style=\x27width:\x20100%;\x20height:\x20100%;\x20object-fit:\x20contain;\x27>','behaviorOnClose':'minimize','notificationId':'messenger-notification-icon','content':{'type':'messenger','contacts':[{'id':'me','name':'Me\x20(Ishant)','avatar':'😎','isMe':!![],'designation':'Designer','linkedin':'https://linkedin.com/in/ishant-periwal','messages':[{'from':'them','text':'Hey\x20there!\x20I\x27m\x20Ishant\x20—\x20a\x20designer\x20passionate\x20about\x20crafting\x20beautiful,\x20functional\x20experiences.\x20Welcome\x20to\x20my\x20portfolio!'}]},{'id':'manager','name':'Anoop\x20Sethumandhavan','avatar':'openAssets/contacts/anoop.jpg','designation':'Design\x20Manager','linkedin':'https://linkedin.com/in/','messages':[{'from':'me','text':'Hey\x20Anoop,\x20hope\x20you\x27re\x20doing\x20well!\x20Could\x20you\x20share\x20a\x20quick\x20blurb\x20about\x20my\x20trajectory\x20at\x20Zeta\x20that\x20I\x20can\x20feature\x20as\x20a\x20manager\x20testimonial\x20in\x20my\x20portfolio?'},{'from':'them','text':'Hey\x20Ishant,\x20absolutely\x20-\x20here\x20you\x20go\x20👇\x20(and\x20hi\x20to\x20whoever\x27s\x20snooping\x20around\x20the\x20portfolio\x20👀)'},{'from':'them','text':'I\x20had\x20the\x20absolute\x20pleasure\x20of\x20managing\x20Ishant\x20directly\x20for\x20over\x20four\x20years\x20at\x20Zeta.\x20He\x20initially\x20joined\x20the\x20team\x20as\x20a\x20Motion\x20Designer\x20and\x20immediately\x20set\x20a\x20high\x20bar,\x20successfully\x20executing\x20end-to-end\x20motion\x20design\x20requirements\x20for\x20major\x20initiatives,\x20including\x20PayZapp\x20and\x20several\x20other\x20high-impact\x20projects.'},{'from':'them','text':'What\x20truly\x20sets\x20Ishant\x20apart\x20is\x20his\x20drive\x20to\x20grow\x20and\x20expand\x20his\x20impact.\x20While\x20excelling\x20in\x20motion,\x20he\x20proactively\x20stepped\x20up\x20to\x20become\x20a\x20UX\x20Design\x20Generalist,\x20taking\x20on\x20full\x20ownership\x20of\x20end-to-end\x20module\x20experiences.\x20His\x20craft\x20is\x20exceptional\x20-\x20highly\x20creative,\x20deeply\x20polished,\x20and\x20always\x20user-centric.'},{'from':'them','text':'Ishant\x20is\x20a\x20rare\x20hybrid\x20of\x20a\x20creative\x20visionary\x20and\x20a\x20technical\x20problem-solver.\x20He\x20would\x20be\x20a\x20massive\x20asset\x20to\x20any\x20design\x20team,\x20and\x20I\x20highly\x20recommend\x20him.'},{'from':'me','text':'Thanks!\x20This\x20one\x27s\x20taking\x20the\x20top\x20spot.\x20❤️'}]},{'id':'bestfriend','name':'Vibhore\x20Singhal','avatar':'openAssets/contacts/vibhore.jpg','designation':'The\x20Wingman','linkedin':'https://www.linkedin.com/in/vibhoresinghal/','messages':[{'from':'them','text':'Hey\x20ssup!'},{'from':'me','text':'Yo\x20how\x27s\x20it\x20going?'},{'from':'them','text':'Man,\x20I\x20really\x20miss\x20working\x20with\x20you.\x20🥲'},{'from':'them','text':'I\x27ve\x20been\x20thinking\x20about\x20the\x20PayZapp\x20days\x20a\x20lot\x20lately,\x20and\x20honestly,\x20those\x20were\x20some\x20of\x20the\x20most\x20fun\x20projects\x20I\x27ve\x20worked\x20on.\x20From\x20building\x20the\x20visual\x20language\x20from\x20the\x20ground\x20up\x20to\x20geeking\x20out\x20over\x20motion,\x20micro-interactions,\x20gamification,\x20and\x20all\x20the\x20tiny\x20details.\x20We\x20were\x20always\x20cooking\x20up\x20something\x20fun.'},{'from':'them','text':'What\x20I\x20miss\x20the\x20most\x20is\x20how\x20easy\x20it\x20was\x20to\x20bounce\x20ideas\x20off\x20each\x20other.\x20We\x27d\x20start\x20with\x20one\x20thought,\x20go\x20down\x20a\x20dozen\x20rabbit\x20holes,\x20and\x20somehow\x20end\x20up\x20with\x20something\x20way\x20better\x20than\x20what\x20we\x20had\x20in\x20mind.\x20It\x20never\x20really\x20felt\x20like\x20work.'},{'from':'them','text':'Feels\x20like\x20it\x27s\x20been\x20forever.'},{'from':'me','text':'damnn!\x20you\x20getting\x20me\x20emotional\x20over\x20here\x20man\x20🥹.\x20good\x20times.'}]},{'id':'teammate','name':'Aditya\x20Sadhukhan','avatar':'openAssets/contacts/aditya.jpg','designation':'Designer','linkedin':'https://www.linkedin.com/in/adityasad/','portfolio':'https://adityaaa.com','messages':[{'from':'me','text':'hey\x20adi!\x20I\x20need\x20some\x20good\x20words\x20from\x20you\x20about\x20how\x20good\x20of\x20a\x20team\x20lead\x20i\x20am\x20💁‍♂️✨'},{'from':'me','text':'for\x20my\x20portfolio'},{'from':'them','text':'I\x20see,\x20but\x20you\x20gotta\x20share\x20how\x20good\x20of\x20a\x20designer\x20i\x20am\x20too\x20😝'},{'from':'them','text':'haha!\x20jokes\x20aside'},{'from':'them','text':'Working\x20with\x20you\x20has\x20honestly\x20been\x20so\x20easy\x20and\x20fun.\x20Thank\x20you\x20for\x20all\x20the\x20learnings!'},{'from':'them','text':'You’re\x20the\x20kind\x20of\x20lead\x20who\x20cuts\x20right\x20through\x20the\x20noise\x20to\x20make\x20the\x20complex\x20look\x20simple.\x20Clean,\x20sharp,\x20thoughtful,\x20always\x20nailing\x20the\x20details,\x20with\x20clever\x20problem\x20solving\x20you\x20made\x20collaboration\x20effortless.'},{'from':'me','text':'This\x20is\x20chatgpt\x20right?'},{'from':'them','text':'but\x20every\x20word\x20is\x20true!'},{'from':'me','text':'haha!\x20okay.\x20thanks\x20bro.\x20🙏'}]},{'id':'pm','name':'Manoj\x20Machiraju','avatar':'openAssets/contacts/manoj.jpg','designation':'Lead\x20Product\x20Manager','linkedin':'https://www.linkedin.com/in/manojkumarraju/','messages':[{'from':'me','text':'Hi\x20Manoj!\x0aThis\x20chat\x20is\x20live\x20on\x20my\x20portfolio.'},{'from':'me','text':'We\x20worked\x20together\x20on\x20Zapp\x20account,\x20would\x20you\x20like\x20to\x20share\x20your\x20work\x20experience\x20with\x20me\x20as\x20a\x20Lead\x20Product\x20Manager\x20on\x20that\x20project?'},{'from':'them','text':'Hello\x20Ishant!\x20Definitely'},{'from':'them','text':'I\x20had\x20the\x20opportunity\x20to\x20work\x20with\x20Ishant\x20for\x20two\x20years\x20across\x20multiple\x20assignments,\x20including\x20prepaid\x20wallet/card\x20user\x20experience\x20(aka\x20Zapp\x20Account),\x20recharge\x20and\x20bill\x20payment\x20flows,\x20and\x20several\x20other\x20product\x20journeys.'},{'from':'them','text':'Ishant\x20brings\x20a\x20very\x20strong\x20user-first\x20approach\x20to\x20design.\x20In\x20the\x20prepaid\x20wallet\x20experience,\x20he\x20contributed\x20meaningfully\x20to\x20features\x20such\x20as\x20spend\x20management,\x20budgeting,\x20and\x20transaction\x20categorisation.\x20His\x20ideas\x20were\x20always\x20creative,\x20practical,\x20and\x20grounded\x20in\x20how\x20users\x20would\x20actually\x20interact\x20with\x20the\x20product.'},{'from':'them','text':'One\x20of\x20the\x20things\x20I\x20appreciated\x20most\x20while\x20working\x20with\x20him\x20was\x20that\x20his\x20designs\x20often\x20felt\x20right\x20in\x20the\x20first\x20version\x20itself.\x20This\x20came\x20from\x20the\x20effort\x20he\x20put\x20in\x20before\x20presenting\x20a\x20solution.\x20He\x20would\x20do\x20his\x20own\x20user\x20study,\x20think\x20deeply\x20about\x20the\x20problem,\x20and\x20still\x20remain\x20open\x20to\x20changing\x20his\x20approach\x20if\x20user\x20insights\x20suggested\x20a\x20better\x20direction.'},{'from':'them','text':'I\x20also\x20enjoyed\x20the\x20many\x20brainstorming\x20discussions\x20we\x20had\x20on\x20how\x20best\x20to\x20communicate\x20ideas\x20to\x20users,\x20whether\x20through\x20icons,\x20colours,\x20placement,\x20animations,\x20or\x20interactions.\x20Ishant\x20has\x20a\x20strong\x20understanding\x20of\x20information\x20architecture\x20and\x20brings\x20clear,\x20experience-backed\x20opinions\x20on\x20what\x20works\x20best\x20for\x20users.'},{'from':'them','text':'Beyond\x20his\x20core\x20work,\x20I\x20have\x20also\x20seen\x20him\x20explore\x20AI-led\x20hobby\x20projects\x20to\x20solve\x20his\x20own\x20day-to-day\x20work\x20problems,\x20which\x20reflects\x20his\x20curiosity\x20and\x20willingness\x20to\x20learn\x20continuously.'},{'from':'them','text':'Ishant\x20is\x20creative,\x20dependable,\x20thoughtful,\x20and\x20highly\x20user-focused.\x20I\x20wish\x20him\x20all\x20the\x20very\x20best\x20for\x20all\x20his\x20future\x20assignments\x20and\x20opportunities.'},{'from':'me','text':'thank\x20you\x20for\x20the\x20kind\x20words\x20Manoj!\x20It\x20has\x20been\x20a\x20pleasure\x20working\x20with\x20you.'}]}]}},'window-fun-3-my-room-1':{'title':'my_computer\x5cfun\x5cmy\x20room','width':0x320,'height':0x258,'top':'10%','left':'20%','content':{'type':'storage','payload':[{'id':'lights-off-1jpg-9es4m','name':'Lights\x20Off.jpg','iconType':'imageFile','description':'','iconSVG':'<svg\x20xmlns=\x22http://www.w3.org/2000/svg\x22\x20viewBox=\x220\x200\x2024\x2024\x22><path\x20fill=\x22#B2EBF2\x22\x20d=\x22M21.4,6.6l-2.8-2.8C18.3,3.5,17.9,3.3,17.5,3.3H6.5C5.7,3.3,5,4,5,4.8v14.4